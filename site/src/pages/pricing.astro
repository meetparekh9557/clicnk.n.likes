---
// Pricing: tiered good-better-best, in the founder's voice. Prices are
// indicative monthly starting points (Terms: confirmed in a written
// proposal). Every rupee figure shown is a deliberate number whose digits
// sum to 6 or 7. Structured to serve both ends the founder flagged: a
// small business that cannot start at premium, and a premium buyer who
// would not trust an agency that only ever looks cheap.
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import QuoteCalculator from '../components/islands/QuoteCalculator.jsx';
import CustomQuote from '../components/islands/CustomQuote.jsx';
import { withBase } from '../lib/url';
import { abs, breadcrumbSchema } from '../lib/seo';
import Check from '@lucide/astro/icons/check';

const tiers = [
  {
    name: 'Launch',
    price: '₹16,000',
    inr: 16000,
    cadence: '/month',
    for: 'For the business ready to own one channel properly before adding more.',
    highlight: false,
    features: [
      'One channel, run in full: SEO, Local, Social, Content or Paid',
      'Monthly reporting tied to leads and calls, not impressions',
      'A quarterly strategy review, in plain language',
      'A free readiness check to set the honest starting point',
    ],
    cta: 'Start with Launch',
  },
  {
    name: 'Growth',
    price: '₹42,000',
    inr: 42000,
    cadence: '/month',
    for: 'For the business ready to run the organic engine across channels, not just one.',
    highlight: true,
    features: [
      'Two to three channels, coordinated under one strategy',
      'Content built to rank on Google and be cited by AI answers',
      'Monthly strategy, not just a report dropped in your inbox',
      'Reporting tied to the leads and enquiries generated, and what each one costs',
      'Priority turnaround on the work that moves your numbers',
    ],
    cta: 'Choose Growth',
  },
  {
    name: 'Partner',
    price: '₹1,50,000',
    inr: 150000,
    cadence: '/month',
    for: 'For the business treating growth as a core function, across the full stack.',
    highlight: false,
    features: [
      'All seven channels available, sequenced to a growth roadmap',
      'A dedicated strategist who owns the whole picture',
      'Website and conversion work built on the same strategy',
      'Weekly reporting on cost per lead and cost per booking',
      'First call on our capacity when a launch or push is time-critical',
    ],
    cta: 'Talk about Partner',
  },
];

const notes = [
  { h: 'Ad spend is always separate', t: 'Paid budget is billed directly by Meta or Google from your own card, never routed through us. Our fee covers strategy, setup, creative and management only.' },
  { h: 'Websites are quoted per project', t: 'A website build is scoped to what it needs to do, not a monthly line, and handed over with no lock-in to a proprietary builder.' },
  { h: 'Every number is confirmed in writing', t: 'These are honest starting points. Your exact scope and price are set in a written proposal before any engagement begins.' },
];

// Published tier prices, expressed as an OfferCatalog. Amounts are the
// monthly starting fees shown on the page (INR), tied to the org as seller.
const tierAmounts: Record<string, number> = { Launch: 16000, Growth: 42000, Partner: 150000 };
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'OfferCatalog',
    name: 'Click.n.likes growth plans',
    url: abs('/pricing/'),
    itemListElement: tiers.map((t) => ({
      '@type': 'Offer',
      name: t.name,
      description: t.for,
      priceCurrency: 'INR',
      price: tierAmounts[t.name],
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: tierAmounts[t.name],
        priceCurrency: 'INR',
        unitText: 'MONTH',
      },
      seller: { '@id': 'https://clicknlikes.com/#organization' },
    })),
  },
  breadcrumbSchema([
    ['Home', '/'],
    ['Pricing', '/pricing/'],
  ]),
];
---

<Base
  title="Pricing: Organic Growth Plans from ₹16,000/mo | Click.n.likes"
  description="Transparent, tiered pricing for organic growth: Launch, Growth and Partner, from ₹16,000/month. Real work at every stage, no hidden retainers, ad spend always separate."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-[5vw] pt-16 pb-8 lg:pt-20">
    <p class="reveal inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy">
      <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> Pricing
    </p>
    <h1 class="reveal-mask mt-5 max-w-3xl font-display text-[clamp(2.1rem,4.4vw,3.4rem)] leading-[1.08] font-bold text-navy">
      <span class="mask-line"><span>Pricing you can see,</span></span>
      <span class="mask-line" style="--d:120ms"><span>before you ever book a call.</span></span>
    </h1>
    <p class="reveal mt-5 max-w-2xl text-lg leading-relaxed text-navy/70" style="--d:240ms">
      Most agencies hide their pricing behind a sales call because the number is the weakest part of the pitch. We
      publish ours, because the businesses we work best with, from a local storefront to a manufacturer or a SaaS
      company, would rather start from an honest figure than a guarded one. There is a real entry point here, and there
      is real depth above it.
    </p>
  </section>

  <!-- Tiers -->
  <section class="mx-auto max-w-6xl px-[5vw] pb-6">
    <!-- Currency switcher: auto-detects the visitor's currency and converts
         the INR pricing at that day's live rate. Progressive enhancement -
         with no JS it simply shows the honest INR figures. -->
    <div class="reveal mb-6 flex flex-wrap items-center gap-x-3 gap-y-1.5">
      <label for="cnlCurrency" class="text-[13px] font-semibold text-navy/70">Show prices in</label>
      <select id="cnlCurrency" class="rounded-full border-[1.5px] border-navy/15 bg-white px-3.5 py-1.5 text-[13px] font-semibold text-navy outline-none focus:border-teal"></select>
      <span id="cnlFxNote" class="text-[12px] text-navy/45"></span>
    </div>
    <div class="grid gap-5 lg:grid-cols-3 lg:items-start">
      {tiers.map((tier, i) => (
        <Card
          class={`reveal flex flex-col ${tier.highlight ? 'border-teal/60 shadow-[0_18px_44px_rgba(26,43,74,0.10)] lg:-mt-3 lg:pb-8' : ''}`}
          style={`--d:${i * 90}ms`}
        >
          {tier.highlight && (
            <span class="absolute -top-3 left-7 rounded-full bg-teal px-3 py-1 text-[11px] font-bold tracking-[0.08em] text-navy uppercase">Most chosen</span>
          )}
          <h2 class="font-display text-lg font-semibold text-navy">{tier.name}</h2>
          <div class="mt-3 flex items-baseline gap-1">
            <span class="cnl-price font-display text-4xl font-bold text-navy" data-inr={tier.inr}>{tier.price}</span>
            <span class="text-sm text-navy/55">{tier.cadence}</span>
          </div>
          <p class="mt-1 text-[13px] text-navy/45">indicative starting point</p>
          <p class="mt-4 text-[14.5px] leading-relaxed text-navy/70">{tier.for}</p>
          <ul class="mt-6 flex-1 space-y-3">
            {tier.features.map((f) => (
              <li class="flex gap-2.5 text-[14px] leading-relaxed text-navy/75">
                <span class="mt-0.5 grid h-[18px] w-[18px] shrink-0 place-items-center rounded-full bg-teal/15 text-teal-dark"><Check size={12} stroke-width={3} aria-hidden="true" /></span>
                {f}
              </li>
            ))}
          </ul>
          <a
            href={withBase('/contact/')}
            data-magnetic
            class={`mt-7 inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition-all duration-300 ease-out-quart hover:-translate-y-0.5 ${
              tier.highlight ? 'bg-navy text-white hover:bg-coral' : 'border-[1.5px] border-navy/15 text-navy hover:border-teal hover:text-teal-dark'
            }`}
          >
            {tier.cta}
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </Card>
      ))}
    </div>
    <p class="reveal mt-6 text-center text-sm text-navy/55" style="--d:120ms">
      Want your exact number? <a href="#quote" class="font-semibold text-teal-dark underline decoration-teal/40 underline-offset-2 hover:decoration-teal">Build an instant quote</a> below, tuned to the exact scope you need.
    </p>
  </section>

  <!-- Instant quote calculator (live) -->
  <section id="quote" class="scroll-mt-28 border-t border-navy/10">
    <div class="mx-auto max-w-6xl px-[5vw] py-16">
      <div class="mx-auto max-w-2xl text-center">
        <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Instant quote</p>
        <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
          Build your exact number in a minute.
        </h2>
        <p class="reveal mt-3 text-lg text-navy/70" style="--d:140ms">
          Pick your services and dial in the scope. Every service starts from a flat ₹16,000 base and adds only the
          line items you choose, the honest sum, never rounded to a nicer figure.
        </p>
      </div>
      <div class="reveal mt-10" style="--d:180ms">
        <QuoteCalculator client:visible />
      </div>
    </div>
  </section>

  <!-- Custom quote builder (industry-aware, email-gated, unique reference) -->
  <section id="custom" class="scroll-mt-28 border-t border-navy/10 bg-off">
    <div class="mx-auto max-w-6xl px-[5vw] py-16">
      <div class="mx-auto max-w-2xl text-center">
        <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Custom quote</p>
        <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
          Need it built around your industry?
        </h2>
        <p class="reveal mt-3 text-lg text-navy/70" style="--d:140ms">
          Tell us your industry, what you want built and how hard you want to push. We build your number now, stamp it
          with a unique reference, and send the full breakdown you can turn into a proposal. Your industry shapes the
          plan, never the price.
        </p>
      </div>
      <div class="reveal mt-10" style="--d:180ms">
        <CustomQuote client:visible />
      </div>
    </div>
  </section>

  <!-- The honest notes -->
  <section class="border-t border-navy/10 bg-off">
    <div class="mx-auto max-w-6xl px-[5vw] py-16">
      <div class="mx-auto max-w-2xl text-center">
        <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">No fine print</p>
        <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
          What the number does, and does not, include.
        </h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-3">
        {notes.map((n, i) => (
          <Card class="reveal" style={`--d:${i * 90}ms`}>
            <h3 class="font-display text-base font-semibold text-navy">{n.h}</h3>
            <p class="mt-2 text-sm leading-relaxed text-navy/65">{n.t}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="mx-auto max-w-3xl px-[5vw] py-16">
    <p class="reveal text-xs font-semibold tracking-[0.14em] text-teal-dark uppercase">Why publish it at all</p>
    <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.15] font-bold text-navy" style="--d:60ms">
      A price you can see is the first proof that the work behind it is real.
    </h2>
    <div class="reveal mt-6 space-y-5 text-[17px] leading-relaxed text-navy/75" style="--d:120ms">
      <p>
        We kept a genuine entry point at ₹16,000 a month on purpose, because a small business that is not yet ready
        for a full engagement still deserves work done properly, not a watered-down version sold as a favour. And we
        kept real depth above it, because a business ready to treat growth as a core function should never have to
        wonder whether its agency is out of its depth.
      </p>
      <p>
        Wherever you start, the promise is the same: the figure you see is the figure we build against, every result is
        reported against the leads and enquiries it generated rather than vanity metrics, and nothing about the arrangement locks you in.
        That is what transparent pricing is for, not a discount, but a signal that there is nothing here we need to
        hide until you are already on a call.
      </p>
    </div>
  </section>

  <script>
    import { CURRENCIES, detectCurrency, getCurrency, setCurrency, loadRates, formatMoney, onCurrency } from '../lib/currency.js';

    function initCurrency() {
      const select = document.getElementById('cnlCurrency');
      const note = document.getElementById('cnlFxNote');
      if (!select) return;
      if (!select.options.length) {
        for (const [code, c] of Object.entries(CURRENCIES)) {
          const o = document.createElement('option');
          o.value = code;
          o.textContent = c.label;
          select.appendChild(o);
        }
      }
      let fx = { rates: null, live: false };

      const apply = () => {
        const cur = getCurrency();
        select.value = cur;
        document.querySelectorAll('.cnl-price').forEach((el) => {
          const inr = parseInt(el.getAttribute('data-inr'), 10);
          if (!Number.isNaN(inr)) el.textContent = formatMoney(inr, cur, fx.rates);
        });
        if (note) {
          if (cur === 'INR') note.textContent = 'In Indian Rupees. Switch if you are elsewhere.';
          else if (fx.rates && fx.rates[cur]) note.textContent = `Shown in your currency at today's rate${fx.live ? '' : ' (last available)'}, confirmed in the written proposal.`;
          else note.textContent = 'Live rate unavailable, showing our base INR pricing.';
        }
      };

      const cur0 = detectCurrency();
      window.__cnlCur = cur0;
      select.value = cur0;
      apply();
      loadRates().then((r) => { fx = r; apply(); });
      select.addEventListener('change', () => setCurrency(select.value));
      onCurrency(() => apply());
    }

    initCurrency();
    document.addEventListener('astro:page-load', initCurrency);
  </script>
</Base>
