---
// Contact page: the direct line. Message form (logs a lead + sends a
// confirmation via the shared engine, same as v1) plus contact detail
// cards with icons and a live-scan nudge. hideCta because this page IS
// the conversion surface - a second CTA band would be noise.
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import SimpleForm from '../components/islands/SimpleForm.jsx';
import { contact } from '../data/site';
import { withBase } from '../lib/url';
import { breadcrumbSchema } from '../lib/seo';

const jsonLd = breadcrumbSchema([
  ['Home', '/'],
  ['Contact', '/contact/'],
]);

const formFields = [
  { name: 'name', label: 'Full name', placeholder: 'Your name' },
  { name: 'email', label: 'Email', type: 'email', placeholder: 'you@business.com' },
  { name: 'business', label: 'Business name', placeholder: 'Your business', required: false, optional: 'optional' },
  { name: 'phone', label: 'WhatsApp number', type: 'tel', placeholder: '+91 98765 43210', required: false, optional: 'optional, for a faster reply' },
  { name: 'service', label: 'What do you need help with?', type: 'select', optional: 'optional', emptyFirst: true, options: ['Not sure yet, help me figure it out', 'SEO (Organic & On-Page)', 'Local SEO & Google Business', 'AI SEO & AI Overviews', 'Social Media Growth', 'Content Marketing', 'Website Development', 'Paid Campaigns'] },
  { name: 'message', label: 'Tell us where you are stuck', type: 'textarea', placeholder: 'The one thing holding your growth back right now. Be honest, we will be honest back.' },
];

const channels = [
  {
    label: 'Email',
    value: contact.email,
    href: `mailto:${contact.email}`,
    note: 'Replies within one business day.',
    icon: 'mail',
  },
  {
    label: 'WhatsApp',
    value: contact.whatsappDisplay,
    href: contact.whatsappHref,
    note: 'Fastest way to reach a strategist.',
    icon: 'whatsapp',
  },
  {
    label: 'Based in',
    value: 'Ahmedabad & Mumbai',
    note: 'Serving clients worldwide.',
    icon: 'pin',
  },
];
---

<Base
  title="Contact & Instant Quote | Click.n.likes"
  description="Talk to a strategist, not a bot. Message us, WhatsApp us, or build an instant quote - and get an honest read on what growth is realistic for your business."
  hideCta
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-6xl px-[5vw] pt-16 pb-10 lg:pt-20">
    <p class="reveal inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy">
      <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> Contact
    </p>
    <h1 class="reveal-mask mt-5 max-w-3xl font-display text-[clamp(2.1rem,4.4vw,3.4rem)] leading-[1.08] font-bold text-navy">
      <span class="mask-line"><span>Tell us where you are stuck.</span></span>
      <span class="mask-line" style="--d:120ms"><span>We will tell you what is realistic.</span></span>
    </h1>
    <p class="reveal mt-5 max-w-2xl text-lg leading-relaxed text-navy/70" style="--d:240ms">
      Whether you run a SaaS product, a factory, a legal practice, a D2C brand or a local storefront, every message
      lands with a strategist who has worked in categories like yours, never a sales bot.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-[5vw] pb-16">
    <div class="grid gap-8 lg:grid-cols-[1.4fr_0.9fr] lg:items-start">
      <div class="reveal">
        <SimpleForm
          client:visible
          tag="contact-message"
          fields={formFields}
          submitLabel="Send message"
          contactHref={withBase('/contact/')}
          toolsHref={withBase('/tools/')}
        />
      </div>

      <aside class="reveal space-y-4" style="--d:120ms">
        {channels.map((c) => (
          <Card class="p-6">
            <div class="flex items-start gap-4">
              <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-teal/10 text-teal-dark">
                {c.icon === 'mail' && (
                  <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                )}
                {c.icon === 'whatsapp' && (
                  <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.5 0-9.96 4.46-9.96 9.96 0 1.76.46 3.45 1.34 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22c5.5 0 9.96-4.46 9.96-9.96 0-2.66-1.04-5.16-2.92-7.04A9.9 9.9 0 0 0 12.04 2zm0 18.13a8.23 8.23 0 0 1-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.19 8.19 0 0 1 2.41 5.83c0 4.55-3.7 8.24-8.24 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.7-.81-.23-.08-.39-.12-.56.13-.16.24-.64.8-.78.97-.15.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.5.11-.11.25-.29.37-.43.12-.15.16-.25.25-.42.08-.16.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43l-.48-.01c-.16 0-.43.06-.66.31-.22.24-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.16 1.75 2.67 4.24 3.75.59.25 1.05.4 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.47-.6 1.68-1.18.2-.58.2-1.08.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
                )}
                {c.icon === 'pin' && (
                  <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 12-9 12S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                )}
              </div>
              <div class="min-w-0">
                <p class="text-xs font-semibold tracking-[0.1em] text-navy/45 uppercase">{c.label}</p>
                {c.href ? (
                  <a href={c.href} target={c.icon === 'whatsapp' ? '_blank' : undefined} rel={c.icon === 'whatsapp' ? 'noopener' : undefined} class="mt-1 block break-words font-display text-[15px] font-semibold text-navy transition-colors hover:text-teal-dark">{c.value}</a>
                ) : (
                  <p class="mt-1 font-display text-[15px] font-semibold text-navy">{c.value}</p>
                )}
                <p class="mt-1 text-[13px] text-navy/55">{c.note}</p>
              </div>
            </div>
          </Card>
        ))}

        <Card class="bg-navy p-6 text-white">
          <p class="text-xs font-semibold tracking-[0.1em] text-white/50 uppercase">Not ready to talk yet?</p>
          <p class="mt-2 text-[15px] leading-relaxed text-white/80">
            Get a live Website Health Score first. Real fetch of your actual page, 11 verified signals, full report
            emailed, no call required.
          </p>
          <a
            href={withBase('/tools/')}
            class="mt-4 inline-flex items-center gap-2 rounded-full bg-teal px-5 py-3 text-sm font-semibold text-navy transition-all duration-300 ease-out-quart hover:-translate-y-0.5 hover:bg-white"
          >
            Scan my site free
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </Card>
      </aside>
    </div>
  </section>
</Base>
