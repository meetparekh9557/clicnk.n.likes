---
// Terms of Use. Content ported verbatim in substance from v1, em dashes
// removed, plain-English register kept. Static legal page.
import Base from '../layouts/Base.astro';
import { contact } from '../data/site';

const sections = [
  {
    h: 'Free tools & scores',
    p: 'Our free tools produce directional estimates from a documented, transparent scoring model, using either data fetched live from a page you submit or answers you self-report, and each result is labelled which. They are not a substitute for a full professional audit and carry no guarantee of outcomes.',
  },
  {
    h: 'Quotations',
    p: 'Prices generated by the quote calculator are genuine and current, but they are indicative starting points. Final scope and pricing are confirmed in a written proposal before any engagement begins. Ad spend on paid platforms is always billed directly by the platform, never through us.',
  },
  {
    h: 'No ranking guarantees',
    p: "No honest agency can guarantee a specific search ranking, and we don't. We guarantee the work: the audits, fixes, content and reporting we commit to in a proposal.",
  },
  {
    h: 'Content of this site',
    p: "All content, tools and design on clicknlikes.com belong to Click.n.likes. You're welcome to link to anything, but please do not republish our tools or content as your own.",
  },
  {
    h: 'Questions',
    plink: true,
  },
];
---

<Base
  title="Terms of Use | Click.n.likes"
  description="The ground rules for using clicknlikes.com: our free tools are honest estimates, our quotes are starting points, and nothing here replaces a signed proposal."
>
  <section class="mx-auto max-w-3xl px-[5vw] pt-16 pb-6 lg:pt-20">
    <p class="reveal inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy">
      <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> Legal
    </p>
    <h1 class="reveal-mask mt-5 font-display text-[clamp(2rem,4vw,3rem)] leading-[1.1] font-bold text-navy">
      <span class="mask-line"><span>Terms of Use</span></span>
    </h1>
    <p class="reveal mt-4 text-lg leading-relaxed text-navy/70" style="--d:140ms">
      Short version: our free tools are honest estimates, our quotes are starting points, and nothing here replaces a
      signed agreement. Last updated: July 2026.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-[5vw] pb-16">
    <div class="space-y-8">
      {sections.map((s, i) => (
        <div class="reveal" style={`--d:${i * 60}ms`}>
          <h2 class="font-display text-lg font-semibold text-navy">{s.h}</h2>
          {s.plink ? (
            <p class="mt-2 text-[15.5px] leading-relaxed text-navy/70">
              Write to{' '}
              <a href={`mailto:${contact.email}`} class="font-medium text-teal-dark underline decoration-teal/40 underline-offset-2 hover:decoration-teal">{contact.email}</a>.
            </p>
          ) : (
            <p class="mt-2 text-[15.5px] leading-relaxed text-navy/70">{s.p}</p>
          )}
        </div>
      ))}
    </div>
  </section>
</Base>
