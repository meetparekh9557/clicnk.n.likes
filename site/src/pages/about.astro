---
// About page, ported from v1: origin story, how-we're-built card,
// how-we-work trio (incl. the profit-reporting note), contact form.
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import SimpleForm from '../components/islands/SimpleForm.jsx';
import { withBase } from '../lib/url';
import Clock from '@lucide/astro/icons/clock';
import MessageSquare from '@lucide/astro/icons/message-square';
import Zap from '@lucide/astro/icons/zap';

const formFields = [
  { name: 'name', label: 'Full name', placeholder: 'Your name' },
  { name: 'email', label: 'Email', type: 'email', placeholder: 'you@business.com' },
  { name: 'business', label: 'Business name', placeholder: 'Your business', required: false, optional: 'optional' },
  { name: 'phone', label: 'WhatsApp number', type: 'tel', placeholder: '+91 98765 43210', required: false, optional: 'optional, for a faster reply' },
  { name: 'message', label: "What's the one thing holding your growth back right now?", type: 'textarea', placeholder: "Tell us honestly, we'll be honest back" },
];
---

<Base
  title="About | Click.n.likes"
  description="Click.n.likes is a full-stack organic growth agency for local service businesses and D2C founders — built for owners already burned by agencies that promised the world and delivered a follower count."
>
  <section class="mx-auto grid max-w-6xl gap-12 px-[5vw] pt-16 pb-14 lg:grid-cols-2 lg:items-center lg:pt-20">
    <div>
      <p class="reveal inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy">
        <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> About Click.n.likes
      </p>
      <h1 class="reveal-mask mt-5 font-display text-[clamp(2.1rem,4.4vw,3.4rem)] leading-[1.08] font-bold text-navy">
        <span class="mask-line"><span>We started this agency because</span></span>
        <span class="mask-line" style="--d:120ms"><span>most agencies waste your money.</span></span>
      </h1>
      <p class="reveal mt-5 text-lg leading-relaxed text-navy/70" style="--d:240ms">
        Click.n.likes is a full-stack organic growth agency for local service businesses and D2C founders. We exist
        for the business owner who's already been burned by an agency that promised the world and delivered a
        follower count.
      </p>
      <p class="reveal mt-4 text-lg leading-relaxed text-navy/70" style="--d:320ms">
        Every service we run, SEO, AI Search, content, social, websites and paid, ties back to one thing: does this
        get you an actual customer.
      </p>
    </div>
    <div class="reveal" style="--d:160ms">
      <Card class="p-8">
        <div class="flex items-center justify-between">
          <b class="font-display text-base font-semibold text-navy">How we're built</b>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-teal/10 px-3 py-1 text-xs font-semibold text-teal-dark">
            <i class="h-1.5 w-1.5 rounded-full bg-teal"></i> 2024 →
          </span>
        </div>
        <ul class="mt-6 space-y-5">
          <li class="flex gap-3.5"><span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-teal"></span><span class="text-[15px] text-navy/80"><b class="text-navy">Full-stack, not siloed.</b> SEO, content, social and web all sit under one strategist.</span></li>
          <li class="flex gap-3.5"><span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-teal"></span><span class="text-[15px] text-navy/80"><b class="text-navy">Niche-first.</b> Dentists and D2C founders get completely different playbooks.</span></li>
          <li class="flex gap-3.5"><span class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-teal"></span><span class="text-[15px] text-navy/80"><b class="text-navy">Built to scale globally.</b> Same rigor, priced for growth-stage businesses anywhere, from ₹16,000.</span></li>
        </ul>
      </Card>
    </div>
  </section>

  <section class="border-y border-navy/10 bg-off">
    <div class="mx-auto max-w-6xl px-[5vw] py-16">
      <div class="mx-auto max-w-2xl text-center">
        <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">How we work</p>
        <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
          No sugarcoating. Just what's working and what isn't.
        </h2>
        <p class="reveal mt-4 text-lg text-navy/70" style="--d:140ms">
          And one number we report that most agencies don't: not just revenue, but <b class="text-navy">profit</b>. A
          ₹50,000 month means nothing if it costs ₹60,000 to generate it, so every report breaks out what a result
          was actually worth after cost, not just the traffic or revenue headline.
        </p>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-3">
        <Card class="reveal" style="--d:0ms">
          <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-teal/10 text-teal-dark"><Clock size={20} stroke-width={2} aria-hidden="true" /></div>
          <h3 class="font-display text-base font-semibold text-navy">Research first</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-navy/60">We study your competitors before we write a word of strategy or copy.</p>
        </Card>
        <Card class="reveal" style="--d:90ms">
          <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-teal/10 text-teal-dark"><MessageSquare size={20} stroke-width={2} aria-hidden="true" /></div>
          <h3 class="font-display text-base font-semibold text-navy">Plain language</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-navy/60">No jargon-heavy decks. If we can't explain it simply, we haven't understood it yet.</p>
        </Card>
        <Card class="reveal" style="--d:180ms">
          <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-teal/10 text-teal-dark"><Zap size={20} stroke-width={2} aria-hidden="true" /></div>
          <h3 class="font-display text-base font-semibold text-navy">Honest timelines</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-navy/60">Organic growth takes months, not days. We tell you that upfront, every time.</p>
        </Card>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-[5vw] py-16 text-center">
    <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Let's talk</p>
    <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
      Have a project in mind? Tell us where you're stuck.
    </h2>
    <div class="reveal mt-8" style="--d:160ms">
      <SimpleForm
        client:visible
        tag="about"
        fields={formFields}
        submitLabel="Talk to us"
        contactHref={withBase('/contact/')}
        toolsHref={withBase('/tools/')}
      />
    </div>
  </section>
</Base>
