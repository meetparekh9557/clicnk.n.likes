---
// Service page template: hero, what's-included bento, free-tool teaser
// and quote CTA. Content comes from src/data/services.ts (ported from
// v1). When the tools migrate (highest-risk milestone), each service's
// gated tool island + quote calculator embed directly into the two
// marked sections below, replacing the /tools/ and /contact/ links.
import Base from '../../layouts/Base.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import InlineCta from '../../components/InlineCta.astro';
import StatTile from '../../components/StatTile.astro';
import FirstPageCliff from '../../components/islands/FirstPageCliff.jsx';
import GatedTool from '../../components/islands/GatedTool.jsx';
import { serviceDetails, serviceProof, serviceDeepDive } from '../../data/services';
import { toolConfigs } from '../../data/toolConfigs';
import { withBase } from '../../lib/url';
import { breadcrumbSchema, serviceSchema } from '../../lib/seo';
import LayoutTemplate from '@lucide/astro/icons/layout-template';
import Search from '@lucide/astro/icons/search';
import Zap from '@lucide/astro/icons/zap';
import Newspaper from '@lucide/astro/icons/newspaper';
import MapPin from '@lucide/astro/icons/map-pin';
import Link2 from '@lucide/astro/icons/link-2';
import Star from '@lucide/astro/icons/star';
import Trophy from '@lucide/astro/icons/trophy';
import Quote from '@lucide/astro/icons/quote';
import CodeXml from '@lucide/astro/icons/code-xml';
import Network from '@lucide/astro/icons/network';
import Radar from '@lucide/astro/icons/radar';
import Calendar from '@lucide/astro/icons/calendar';
import PenLine from '@lucide/astro/icons/pen-line';
import Palette from '@lucide/astro/icons/palette';
import MessageCircle from '@lucide/astro/icons/message-circle';
import NotebookPen from '@lucide/astro/icons/notebook-pen';
import FileText from '@lucide/astro/icons/file-text';
import Sparkles from '@lucide/astro/icons/sparkles';
import Gauge from '@lucide/astro/icons/gauge';
import MousePointerClick from '@lucide/astro/icons/mouse-pointer-click';
import ScanSearch from '@lucide/astro/icons/scan-search';
import KeyRound from '@lucide/astro/icons/key-round';
import Megaphone from '@lucide/astro/icons/megaphone';
import Target from '@lucide/astro/icons/target';
import Repeat from '@lucide/astro/icons/repeat';
import ReceiptText from '@lucide/astro/icons/receipt-text';

export function getStaticPaths() {
  return serviceDetails.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const icons: Record<string, any> = {
  'layout-template': LayoutTemplate, search: Search, zap: Zap, newspaper: Newspaper,
  'map-pin': MapPin, 'link-2': Link2, star: Star, trophy: Trophy,
  quote: Quote, 'code-xml': CodeXml, network: Network, radar: Radar,
  calendar: Calendar, 'pen-line': PenLine, palette: Palette, 'message-circle': MessageCircle,
  'notebook-pen': NotebookPen, 'file-text': FileText, sparkles: Sparkles,
  gauge: Gauge, 'mouse-pointer-click': MousePointerClick, 'scan-search': ScanSearch, 'key-round': KeyRound,
  megaphone: Megaphone, target: Target, repeat: Repeat, 'receipt-text': ReceiptText,
};

const { service } = Astro.props;
const proof = serviceProof[service.slug];
const deep = serviceDeepDive[service.slug];
const toolConfig = toolConfigs[service.toolKey];
const servicePath = `/services/${service.slug}/`;

// Per-page SEO meta, written in the founder's voice (not the generic
// "<title> | brand" fallback). Titles in Title Case, descriptions ~155ch.
const serviceMeta: Record<string, { title: string; description: string }> = {
  seo: {
    title: 'SEO That Ranks You for What Buyers Actually Search | Click.n.likes',
    description: 'We build your SEO around the way your category is really searched, so the visitors you earn are the ones who turn into enquiries, not just traffic that looks good in a report.',
  },
  'local-seo': {
    title: 'Local SEO That Wins You the Google Maps Pack | Click.n.likes',
    description: 'The local pack is the shopfront of the modern high street. We sharpen your Google Business Profile, earn you real reviews, and track your rank against the rivals in your own city.',
  },
  'ai-seo': {
    title: 'Be the Business ChatGPT and AI Overviews Cite | Click.n.likes',
    description: 'Search is splitting into blue links and AI answers. We shape your content and schema so that when someone asks an AI about your category, it names you, and not your competitor.',
  },
  'social-media-growth': {
    title: 'Social Growth That Earns a Real Audience | Click.n.likes',
    description: 'Social done the honest way: content and strategy that build a following worth having and turn it into enquiries, judged on the leads it brings you, never the likes.',
  },
  'content-marketing': {
    title: 'Content That Ranks on Google and Gets Cited by AI | Click.n.likes',
    description: 'One buyer question, answered completely. That is how we write content that ranks on Google, gets quoted by AI, and turns a reader into an enquiry instead of a bounce.',
  },
  'website-development': {
    title: 'Websites That Load Fast and Turn Visitors Into Leads | Click.n.likes',
    description: 'A visitor decides in about three seconds. We build sites that answer them fast, load in under two, and are ready to rank from day one, with no lock-in to a proprietary builder.',
  },
  'paid-campaigns': {
    title: 'Paid Ads That Amplify Your Organic Growth | Click.n.likes',
    description: 'Paid works best on a site that already earns its rankings. We run Meta and Google campaigns that amplify your organic engine rather than paper over its gaps. Ad spend stays separate.',
  },
};
const meta = serviceMeta[service.slug] ?? { title: `${service.title} | Click.n.likes`, description: service.lead };
const jsonLd = [
  serviceSchema({ name: service.title, description: service.lead, path: servicePath }),
  breadcrumbSchema([
    ['Home', '/'],
    [service.title, servicePath],
  ]),
];
const iconWrap = 'mb-4 grid h-11 w-11 place-items-center rounded-xl bg-teal/10 text-teal-dark';
const HeroIcon = icons[service.cards[0].icon];
---

<Base
  title={meta.title}
  description={meta.description}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-teal/[0.07] via-transparent to-transparent"></div>
    <div class="mx-auto max-w-6xl px-[5vw] pt-16 pb-12 lg:pt-20">
      <p class="reveal inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy">
        <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> {service.eyebrow}
      </p>
      <h1 class="reveal-mask mt-5 max-w-3xl font-display text-[clamp(2.1rem,4.4vw,3.4rem)] leading-[1.08] font-bold text-navy">
        <span class="mask-line"><span>{service.h1}</span></span>
      </h1>
      <p class="reveal mt-5 max-w-2xl text-lg leading-relaxed text-navy/70" style="--d:160ms">{service.lead}</p>
      <div class="reveal mt-8 flex flex-wrap items-center gap-4" style="--d:260ms">
        <Button href="#tool" arrow magnetic>Run a free readiness check</Button>
        <a href={withBase('/pricing/#quote')} class="text-sm font-semibold text-navy underline-offset-4 transition-colors hover:text-teal-dark hover:underline">or skip straight to pricing →</a>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="mx-auto max-w-6xl px-[5vw] pb-16">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {service.cards.map((c, i) => {
        const Icon = icons[c.icon];
        return (
          <Card class="reveal" style={`--d:${i * 80}ms`}>
            <div class={iconWrap}><Icon size={20} stroke-width={2} aria-hidden="true" /></div>
            <h3 class="font-display text-base font-semibold text-navy">{c.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-navy/60">{c.text}</p>
          </Card>
        );
      })}
    </div>
  </section>

  <!-- Why it matters: real cited proof or honest framing per service -->
  {proof && (
    <section class="border-t border-navy/10">
      <div class="mx-auto max-w-6xl px-[5vw] py-16">
        <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Why it matters</p>
        <div class="mt-8 grid gap-10 lg:grid-cols-2 lg:items-center">
          <div>
            <h2 class="reveal font-display text-[clamp(1.6rem,3vw,2.3rem)] leading-[1.15] font-bold text-navy" style="--d:60ms">
              {proof.title}
            </h2>
            <p class="reveal mt-4 text-lg leading-relaxed text-navy/70" style="--d:140ms">{proof.intro}</p>
          </div>
          <div class="reveal" style="--d:220ms">
            {proof.showCliff && <FirstPageCliff client:visible />}
            {proof.stat && <StatTile value={proof.stat.value} label={proof.stat.label} source={proof.stat.source} class="p-8" />}
            {!proof.showCliff && !proof.stat && proof.note && (
              <Card class="bg-gradient-to-br from-white to-off p-8">
                <div class={iconWrap}><HeroIcon size={22} stroke-width={2} aria-hidden="true" /></div>
                <p class="text-lg leading-relaxed font-medium text-navy">{proof.note}</p>
              </Card>
            )}
          </div>
        </div>
        {(proof.showCliff || proof.stat) && proof.note && (
          <p class="reveal mt-6 max-w-2xl text-sm text-navy/55" style="--d:280ms">{proof.note}</p>
        )}
      </div>
    </section>
  )}

  <!-- Why Click.n.likes: the persuasion layer, founder's voice -->
  {deep && (
    <section class="border-t border-navy/10 bg-off">
      <div class="mx-auto max-w-3xl px-[5vw] py-16">
        <p class="reveal text-xs font-semibold tracking-[0.14em] text-teal-dark uppercase">Why Click.n.likes for {service.title}</p>
        <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.15] font-bold text-navy" style="--d:60ms">
          {deep.heading}
        </h2>
        <p class="reveal mt-5 text-[17px] leading-relaxed text-navy/75" style="--d:120ms">{deep.bridge}</p>

        <ul class="mt-8 space-y-5">
          {deep.pillars.map((p, i) => (
            <li class="reveal flex gap-4" style={`--d:${160 + i * 80}ms`}>
              <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-teal"></span>
              <p class="text-[16px] leading-relaxed text-navy/75">
                <b class="font-semibold text-navy">{p.label}:</b> {p.text}
              </p>
            </li>
          ))}
        </ul>

        <div class="reveal mt-9 rounded-2xl border border-teal/30 bg-white p-6 sm:p-7" style="--d:120ms">
          <p class="text-xs font-semibold tracking-[0.14em] text-teal-dark uppercase">Example in Action</p>
          <p class="mt-2 text-[16px] leading-relaxed text-navy/80">
            <b class="font-semibold text-navy">{deep.example.metric}</b> {deep.example.text}
          </p>
        </div>

        <h3 class="reveal mt-10 font-display text-xl font-bold text-navy" style="--d:80ms">{deep.conclusion.title}</h3>
        <p class="reveal mt-3 text-[17px] leading-relaxed text-navy/75" style="--d:140ms">{deep.conclusion.text}</p>
      </div>
    </section>
  )}

  <!-- Mid-page CTA -->
  <section class="mx-auto max-w-6xl px-[5vw] py-4">
    <InlineCta
      eyebrow={`${service.title}, done right`}
      title={`Ready to put ${service.title} to work for your business?`}
      primaryLabel="Build my instant quote"
      primaryHref="/pricing/#quote"
      secondaryLabel="Run a free check"
      secondaryHref="#tool"
    />
  </section>

  <!-- Free tool: the real gated tool for this service, scored live -->
  <section id="tool" class="scroll-mt-24 border-y border-navy/10 bg-off">
    <div class="mx-auto max-w-3xl px-[5vw] py-16">
      <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Free tool</p>
      <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">{service.tool.name}</h2>
      <p class="reveal mt-3 max-w-xl text-lg text-navy/70" style="--d:140ms">
        {toolConfig?.lead || service.tool.lead}
      </p>
      <div class="reveal mt-8" style="--d:200ms">
        {toolConfig
          ? <GatedTool config={toolConfig} serviceLabel={service.tool.name} client:visible />
          : <p class="text-sm text-navy/60">This check is available from the tools hub.</p>}
      </div>
    </div>
  </section>

</Base>
