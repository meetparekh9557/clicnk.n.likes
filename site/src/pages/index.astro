---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---
<Base title="Click.n.likes | Organic Growth, Engineered" description="Full-stack organic growth agency: SEO, AI Search, Social, Content, Websites and Paid Media.">
  <main class="min-h-screen grid place-items-center p-8">
    <div class="max-w-xl text-center">
      <h1 class="font-display text-4xl font-bold">Phase 2 shell: standing.</h1>
      <p class="mt-4 text-gray-500">Astro + Tailwind + React islands. Real pages, real URLs. The v1 site keeps serving until this one passes every test.</p>
    </div>
  </main>
</Base>
