---
// Article template. Bodies are first-party HTML ported verbatim from
// v1 (data/articles.ts) with root-relative internal links, rebased
// through withBase() so they work at / and /preview/.
import Base from '../../layouts/Base.astro';
import InlineCta from '../../components/InlineCta.astro';
import { articles } from '../../data/articles';
import { withBase } from '../../lib/url';

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const body = article.body.replace(/href="(\/[^"]*)"/g, (_m, p) => `href="${withBase(p)}"`);

// Split the article at a paragraph boundary near the middle so a CTA can
// sit inside the read, not only at the top and bottom. Cutting only at
// </p> keeps every block intact.
const paras = body.split('</p>');
const canSplit = paras.length >= 5;
const mid = Math.ceil(paras.length / 2);
const bodyTop = canSplit ? paras.slice(0, mid).join('</p>') + '</p>' : body;
const bodyRest = canSplit ? paras.slice(mid).join('</p>') : '';
---

<Base title={`${article.title} | Click.n.likes Insights`} description={article.excerpt}>
  <section class="mx-auto max-w-3xl px-[5vw] pt-14 pb-6 lg:pt-18">
    <a href={withBase('/insights/')} class="reveal text-sm font-semibold text-navy/55 transition-colors hover:text-teal-dark">← All insights</a>
    <p class="reveal mt-5 inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy" style="--d:60ms">
      <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> {article.tag}
    </p>
    <h1 class="reveal-mask mt-4 font-display text-[clamp(1.9rem,3.8vw,2.8rem)] leading-[1.12] font-bold text-navy">
      <span class="mask-line"><span>{article.title}</span></span>
    </h1>
    <p class="reveal mt-4 text-sm text-navy/55" style="--d:140ms">{article.author} · {article.readTime}</p>
  </section>

  <section class="mx-auto max-w-3xl px-[5vw] pb-20">
    <div class="article-body reveal" style="--d:200ms" set:html={bodyTop} />
    {canSplit && (
      <div class="my-10">
        <InlineCta
          eyebrow={`More on ${article.tag}?`}
          title="We do this for clients every day. Want it done for you?"
          primaryLabel="Get your instant quote"
          secondaryLabel="Scan my site free"
        />
      </div>
    )}
    {canSplit && <div class="article-body" set:html={bodyRest} />}
  </section>
</Base>
