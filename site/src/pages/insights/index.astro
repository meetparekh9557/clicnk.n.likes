---
// Insights index: article grid + newsletter, ported from v1's blog page.
import Base from '../../layouts/Base.astro';
import NewsletterForm from '../../components/islands/NewsletterForm.jsx';
import { articles } from '../../data/articles';
import { withBase } from '../../lib/url';
import { abs, breadcrumbSchema } from '../../lib/seo';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Click.n.likes Insights',
    description: 'Practical breakdowns on SEO, AI search, social and websites.',
    url: abs('/insights/'),
    publisher: { '@id': 'https://clicknlikes.com/#organization' },
    blogPost: articles.map((a) => ({
      '@type': 'BlogPosting',
      headline: a.title,
      description: a.excerpt,
      url: abs(`/insights/${a.slug}/`),
      datePublished: a.date,
      author: { '@type': 'Organization', name: a.author },
    })),
  },
  breadcrumbSchema([
    ['Home', '/'],
    ['Insights', '/insights/'],
  ]),
];

// Abstract card thumbs, carried over from v1's blog grid.
const thumbs = [
  '<svg viewBox="0 0 300 160" aria-hidden="true"><circle cx="60" cy="80" r="50" fill="#4ECDC4" opacity=".3"/><circle cx="220" cy="50" r="30" fill="#FF4757" opacity=".25"/></svg>',
  '<svg viewBox="0 0 300 160" aria-hidden="true"><rect x="40" y="40" width="90" height="90" rx="14" fill="#FF4757" opacity=".22"/><rect x="160" y="60" width="90" height="60" rx="14" fill="#4ECDC4" opacity=".3"/></svg>',
  '<svg viewBox="0 0 300 160" aria-hidden="true"><circle cx="150" cy="80" r="60" fill="#4ECDC4" opacity=".2"/><circle cx="150" cy="80" r="30" fill="#FF4757" opacity=".25"/></svg>',
  '<svg viewBox="0 0 300 160" aria-hidden="true"><rect x="20" y="30" width="260" height="100" rx="16" fill="#FF4757" opacity=".15"/></svg>',
];
---

<Base
  title="Insights: SEO, AI Search & Content Marketing | Click.n.likes"
  description="Practical breakdowns on SEO, AI search, social and websites, written the way we'd explain it to a client over coffee."
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-6xl px-[5vw] pt-16 pb-10 lg:pt-20">
    <p class="reveal inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy">
      <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> Insights
    </p>
    <h1 class="reveal-mask mt-5 max-w-3xl font-display text-[clamp(2.1rem,4.4vw,3.4rem)] leading-[1.08] font-bold text-navy">
      <span class="mask-line"><span>Straight answers on organic growth, no fluff.</span></span>
    </h1>
    <p class="reveal mt-5 max-w-2xl text-lg leading-relaxed text-navy/70" style="--d:160ms">
      Practical breakdowns on SEO, AI search, social and websites, written the way we'd explain it to a client over
      coffee.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-[5vw] pb-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {articles.map((a, i) => (
        <a
          href={withBase(`/insights/${a.slug}/`)}
          class="reveal group overflow-hidden rounded-2xl border border-navy/10 bg-white transition-all duration-500 ease-out-quart hover:-translate-y-1 hover:border-teal/40 hover:shadow-[0_18px_44px_rgba(26,43,74,0.10)]"
          style={`--d:${(i % 2) * 90}ms`}
        >
          <div class="bg-off [&>svg]:block [&>svg]:w-full" set:html={thumbs[i]} />
          <div class="p-6">
            <span class="rounded-full bg-teal/10 px-3 py-1 text-xs font-semibold text-teal-dark">{a.tag}</span>
            <h3 class="mt-3 font-display text-lg leading-snug font-semibold text-navy">{a.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-navy/60">{a.excerpt}</p>
            <p class="mt-3 text-sm font-semibold text-teal-dark transition-transform duration-300 group-hover:translate-x-0.5">Read article →</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="border-t border-navy/10 bg-off">
    <div class="mx-auto max-w-xl px-[5vw] py-16 text-center">
      <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Newsletter</p>
      <h2 class="reveal mt-3 font-display text-[clamp(1.5rem,2.6vw,2.1rem)] leading-[1.15] font-bold text-navy" style="--d:80ms">
        One growth idea a week. No fluff, unsubscribe anytime.
      </h2>
      <div class="reveal mt-7" style="--d:160ms">
        <NewsletterForm client:visible />
      </div>
    </div>
  </section>
</Base>
