---
// Work page: how we define and measure a result, the industries we grow,
// and a benchmark-request form. It carries NO client metrics until the
// founder supplies real, permissioned numbers - nothing here is invented.
// Phase 4 replaces the "how we measure" framing with real case studies
// built from that material.
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import ClientLogos from '../components/ClientLogos.astro';
import InlineCta from '../components/InlineCta.astro';
import SimpleForm from '../components/islands/SimpleForm.jsx';
import { withBase } from '../lib/url';
import { breadcrumbSchema } from '../lib/seo';

const jsonLd = breadcrumbSchema([
  ['Home', '/'],
  ['Work', '/work/'],
]);

// What a result actually means to us: the signals we can measure and
// stand behind, never a client's private revenue.
const measures = [
  { h: 'Leads and enquiries', t: 'The forms, messages and enquiries the work brings in, attributed to the channel that earned them.' },
  { h: 'Calls and bookings', t: 'Booked calls and appointments, counted through the call and booking tracking we set up, not guessed at.' },
  { h: 'Cost per lead', t: 'What each lead actually costs to earn, so spend is judged on what it returns, not on how busy it looks.' },
  { h: 'Rankings and organic traffic', t: 'Where you rank for the terms that matter, and how much qualified organic traffic that visibility brings, month on month.' },
];

const industries = [
  'SaaS and software', 'Manufacturing and industrial', 'Legal and professional services',
  'D2C and eCommerce', 'Local and multi-location', 'Film and media',
];

const formFields = [
  { name: 'name', label: 'Full name', placeholder: 'Your name' },
  { name: 'category', label: 'Business category', placeholder: 'e.g. dermatology clinic' },
  { name: 'email', label: 'Email', type: 'email', placeholder: 'you@business.com' },
  { name: 'city', label: 'City', placeholder: 'e.g. Ahmedabad, Dubai, London, Toronto' },
  { name: 'phone', label: 'WhatsApp number', type: 'tel', placeholder: '+91 98765 43210', required: false, optional: 'optional, for a faster reply' },
  { name: 'budget', label: 'Monthly budget range', type: 'select', optional: 'optional', emptyFirst: true, options: ['Prefer not to say yet', 'Under ₹16,000', '₹16,000 - ₹40,000', '₹40,000 - ₹1,00,000', '₹1,00,000+'] },
];
---

<Base
  title="Our Work & How We Measure Growth | Click.n.likes"
  description="How we define a real result: leads, calls, cost per lead and organic rankings, measured honestly and never vanity metrics, across SaaS, manufacturing, legal, D2C and local businesses."
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-6xl px-[5vw] pt-16 pb-10 lg:pt-20">
    <p class="reveal inline-flex items-center gap-2 rounded-full border border-teal/30 bg-teal/5 px-4 py-1.5 text-[13px] font-semibold text-navy">
      <span class="h-1.5 w-1.5 rounded-full bg-teal"></span> Results
    </p>
    <h1 class="reveal-mask mt-5 max-w-3xl font-display text-[clamp(2.1rem,4.4vw,3.4rem)] leading-[1.08] font-bold text-navy">
      <span class="mask-line"><span>A result you can measure,</span></span>
      <span class="mask-line" style="--d:120ms"><span>not a headline you have to trust.</span></span>
    </h1>
    <p class="reveal mt-5 max-w-2xl text-lg leading-relaxed text-navy/70" style="--d:160ms">
      Every engagement is judged against the numbers we can genuinely stand behind: the leads, calls and enquiries the
      work generated, and what each one cost to earn. Not rankings for their own sake, and never a revenue figure only
      your own books can confirm.
    </p>
  </section>

  <!-- How we measure a result -->
  <section class="mx-auto max-w-6xl px-[5vw] pb-16">
    <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">How we measure a result</p>
    <h2 class="reveal mt-3 max-w-2xl font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
      Four numbers we report, and can prove.
    </h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {measures.map((m, i) => (
        <Card class="reveal" style={`--d:${(i % 4) * 80}ms`}>
          <h3 class="font-display text-base font-semibold text-navy">{m.h}</h3>
          <p class="mt-2 text-[13.5px] leading-relaxed text-navy/60">{m.t}</p>
        </Card>
      ))}
    </div>
  </section>

  <!-- Industries -->
  <section class="border-t border-navy/10">
    <div class="mx-auto max-w-6xl px-[5vw] py-16">
      <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Where we drive growth</p>
      <h2 class="reveal mt-3 max-w-2xl font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
        The same fundamentals, adapted to how each market is searched and bought.
      </h2>
      <p class="reveal mt-3 max-w-2xl text-lg text-navy/70" style="--d:140ms">
        From SaaS and manufacturing to legal, film, apparel, jewellery and hospitality, the playbook changes with the
        buyer, an engineer sourcing a supplier searches nothing like a patient booking a clinic.
      </p>
      <div class="reveal mt-8 flex flex-wrap gap-2.5" style="--d:180ms">
        {industries.map((name) => (
          <span class="rounded-full border-[1.5px] border-navy/10 bg-white px-4 py-2 text-[13.5px] font-semibold text-navy/75">{name}</span>
        ))}
      </div>
      <div class="reveal mt-10 rounded-2xl border border-teal/30 bg-teal/[0.05] p-6 sm:p-7" style="--d:220ms">
        <p class="text-[15px] leading-relaxed text-navy/75">
          <b class="font-semibold text-navy">On detailed case studies:</b> we publish them here with real numbers as
          each client gives us permission to share theirs. We would rather map a realistic projection for your own
          category than borrow someone else's headline, so
          <a href={withBase('/tools/')} class="font-semibold text-teal-dark underline decoration-teal/40 underline-offset-2 hover:decoration-teal">run a free check</a>
          or
          <a href={withBase('/contact/')} class="font-semibold text-teal-dark underline decoration-teal/40 underline-offset-2 hover:decoration-teal">tell us your category</a>
          and we will show you what is realistic for you.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-[5vw] pt-14 pb-4">
    <InlineCta
      eyebrow="Your category next"
      title="Want a realistic growth projection mapped for your business?"
      primaryLabel="Get your instant quote"
      secondaryLabel="Run a free check"
    />
  </section>

  <section class="border-t border-navy/10">
    <div class="mx-auto max-w-6xl px-[5vw] py-16">
      <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Clients we have worked with</p>
      <h2 class="reveal mt-3 max-w-2xl font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
        Growth across industries, not just one.
      </h2>
      <p class="reveal mt-3 max-w-2xl text-lg text-navy/70" style="--d:140ms">
        From SaaS and manufacturing to legal, film, apparel, jewellery and hospitality, the playbook adapts to how
        each market is actually searched and bought.
      </p>
      <div class="reveal mt-12" style="--d:200ms">
        <ClientLogos gridCols="grid-cols-3 sm:grid-cols-5" />
      </div>
    </div>
  </section>

  <section class="border-t border-navy/10 bg-off">
    <div class="mx-auto max-w-3xl px-[5vw] py-16 text-center">
      <p class="reveal text-xs font-semibold tracking-[0.14em] text-navy/50 uppercase">Want numbers like these?</p>
      <h2 class="reveal mt-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-[1.12] font-bold text-navy" style="--d:80ms">
        Tell us your category, we'll tell you what's realistic.
      </h2>
      <div class="reveal mt-8" style="--d:160ms">
        <SimpleForm
          client:visible
          tag="work"
          fields={formFields}
          submitLabel="Show me realistic numbers"
          contactHref={withBase('/contact/')}
          toolsHref={withBase('/tools/')}
        />
      </div>
    </div>
  </section>
</Base>
