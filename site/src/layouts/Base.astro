---
// Base layout: every page gets real per-page SEO plus the shared shell
// (Nav, Footer, motion utilities). Brand voice rules live in /CLAUDE.md.
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ChatButton from '../components/ChatButton.astro';
import CtaBand from '../components/CtaBand.astro';
import SiteBackdrop from '../components/SiteBackdrop.astro';
import { ClientRouter } from 'astro:transitions';
import { withBase } from '../lib/url';
import { OG_DEFAULT, ORG_NAME, organizationSchema, webSiteSchema } from '../lib/seo';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  hideCta?: boolean;
  ogImage?: string;
  ogType?: string;
  jsonLd?: unknown | unknown[];
}
const { title, description, canonical, hideCta, ogImage, ogType, jsonLd } = Astro.props;
// Preview builds (clicknlikes.com/preview/) must never be indexed, and
// their canonicals point at the real future URL (base stripped).
const isPreview = import.meta.env.PUBLIC_PREVIEW === '1';
const basePrefix = import.meta.env.BASE_URL.replace(/\/+$/, '');
const cleanPath = basePrefix && Astro.url.pathname.startsWith(basePrefix)
  ? Astro.url.pathname.slice(basePrefix.length) || '/'
  : Astro.url.pathname;
const canonicalURL = canonical ?? new URL(cleanPath, Astro.site).href;
const shareImage = ogImage ?? OG_DEFAULT;
// Site-wide identity graph plus any page-specific schema, deduped into
// one array. Structured data always describes the live production site,
// so it is emitted on preview too (the noindex tag keeps preview out of
// the index; the JSON-LD stays valid for the cutover).
const structuredData = [
  organizationSchema(),
  webSiteSchema(),
  ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []),
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Search Console domain verification. Harmless on preview
         (noindex), needed on production so the property stays verified. -->
    <meta name="google-site-verification" content="CbG8y7rYgHT9oBtl6n8ptMmvLdN_G0rkvGfyp5SlrnQ" />
    <!-- Google Analytics (gtag). Loaded only on the production build, not
         the noindex /preview/ build, so preview/test traffic never lands
         in the analytics. Activates automatically at cutover. -->
    {!isPreview && (
      <>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-150CCHPK6L"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-150CCHPK6L');
        </script>
      </>
    )}
    <!-- Progressive-enhancement flag: lets scroll-triggered animations
         (e.g. the self-drawing charts) start from zero only when JS can
         finish them; without JS the content renders at full state. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    {isPreview && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('/favicon-32.png')} />
    <link rel="icon" type="image/png" sizes="512x512" href={withBase('/favicon.png')} />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType ?? 'website'} />
    <meta property="og:site_name" content={ORG_NAME} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${ORG_NAME} - full-stack organic growth`} />
    <!-- Twitter / X large-image card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="theme-color" content="#1A2B4A" />
    <!-- Structured data: Organization + WebSite site-wide, plus any
         per-page schema passed in via the jsonLd prop. -->
    {structuredData.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}
    <!-- Fonts are self-hosted via @fontsource (imported in global.css);
         no external font request is made. -->
    <!-- View Transitions (Phase 3): SPA-style navigation with a soft cross
         fade. Every inline/DOM script on the site already re-inits on
         astro:page-load, and the fade is skipped under prefers-reduced-
         motion by the browser's own handling of the view-transition API. -->
    <ClientRouter fallback="swap" />
  </head>
  <body class="bg-transparent font-body text-navy antialiased">
    <SiteBackdrop />
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:rounded-lg focus:bg-navy focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main" class="pt-[72px]">
      <slot />
    </main>
    {!hideCta && <CtaBand />}
    <Footer />
    <ChatButton />
    <script src="../scripts/motion.js"></script>
  </body>
</html>
