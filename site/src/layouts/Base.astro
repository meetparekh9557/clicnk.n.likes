---
// Base layout: every page gets real per-page SEO plus the shared shell
// (Nav, Footer, motion utilities). Brand voice rules live in /CLAUDE.md.
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ChatButton from '../components/ChatButton.astro';
import CtaBand from '../components/CtaBand.astro';
import { withBase } from '../lib/url';
import '../styles/global.css';

interface Props { title: string; description: string; canonical?: string; hideCta?: boolean; }
const { title, description, canonical, hideCta } = Astro.props;
// Preview builds (clicknlikes.com/preview/) must never be indexed, and
// their canonicals point at the real future URL (base stripped).
const isPreview = import.meta.env.PUBLIC_PREVIEW === '1';
const basePrefix = import.meta.env.BASE_URL.replace(/\/+$/, '');
const cleanPath = basePrefix && Astro.url.pathname.startsWith(basePrefix)
  ? Astro.url.pathname.slice(basePrefix.length) || '/'
  : Astro.url.pathname;
const canonicalURL = canonical ?? new URL(cleanPath, Astro.site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Search Console domain verification. Harmless on preview
         (noindex), needed on production so the property stays verified. -->
    <meta name="google-site-verification" content="CbG8y7rYgHT9oBtl6n8ptMmvLdN_G0rkvGfyp5SlrnQ" />
    <!-- Google Analytics (gtag). Loaded only on the production build, not
         the noindex /preview/ build, so preview/test traffic never lands
         in the analytics. Activates automatically at cutover. -->
    {!isPreview && (
      <>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-LB423REFGS"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-LB423REFGS');
        </script>
      </>
    )}
    <!-- Progressive-enhancement flag: lets scroll-triggered animations
         (e.g. the self-drawing charts) start from zero only when JS can
         finish them; without JS the content renders at full state. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    {isPreview && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#1A2B4A" />
    <!-- Fonts are self-hosted via @fontsource (imported in global.css);
         no external font request is made. -->
  </head>
  <body class="bg-white font-body text-navy antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:rounded-lg focus:bg-navy focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main" class="pt-[72px]">
      <slot />
    </main>
    {!hideCta && <CtaBand />}
    <Footer />
    <ChatButton />
    <script src="../scripts/motion.js"></script>
  </body>
</html>
