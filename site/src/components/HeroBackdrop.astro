---
// Hero background motion: a flow-field particle current. Discrete glowing
// "orbs" drift along a slowly-churning vector field, with soft bokeh depth
// behind them. The cursor bends the current; as the visitor starts
// scrolling the orbs grow and brighten. Transparent canvas over the hero's
// own background (no trails, so nothing smears), one <canvas>, no library,
// capped particle count, rAF, paused when the hero scrolls out of view,
// and fully still under prefers-reduced-motion. Drop <HeroBackdrop /> as
// the first child of any `position:relative` hero.
---
<div class="hero-fx" aria-hidden="true">
  <span class="hero-fx__glow"></span>
  <canvas class="cnl-field"></canvas>
</div>

<style>
  .hero-fx { position: absolute; inset: 0; z-index: -10; overflow: hidden; pointer-events: none; }
  .hero-fx__glow {
    position: absolute; inset: 0;
    background: radial-gradient(90% 70% at 78% 30%, rgba(78, 205, 196, 0.10), transparent 60%),
                radial-gradient(70% 60% at 8% 80%, rgba(78, 205, 196, 0.06), transparent 55%);
  }
  .cnl-field {
    position: absolute; inset: 0; width: 100%; height: 100%;
    -webkit-mask-image: radial-gradient(125% 100% at 72% 8%, #000 40%, transparent 82%);
    mask-image: radial-gradient(125% 100% at 72% 8%, #000 40%, transparent 82%);
  }
</style>

<script>
  function initField(canvas: HTMLCanvasElement) {
    if ((canvas as any)._cnlInit) return;
    (canvas as any)._cnlInit = true;
    const ctx = canvas.getContext('2d', { alpha: true });
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const host = canvas.parentElement as HTMLElement;

    let W = 0, H = 0, DPR = 1, orbs: any[] = [], bokeh: any[] = [], t = 0, progress = 0, visible = true, raf = 0;
    const mouse = { x: -9999, y: -9999, active: false };
    const TEAL = [78, 205, 196];

    const sprite = (() => {
      const c = document.createElement('canvas'); c.width = c.height = 128;
      const g = c.getContext('2d')!;
      const rad = g.createRadialGradient(64, 64, 0, 64, 64, 64);
      rad.addColorStop(0, 'rgba(78,205,196,0.34)');
      rad.addColorStop(0.5, 'rgba(78,205,196,0.10)');
      rad.addColorStop(1, 'rgba(78,205,196,0)');
      g.fillStyle = rad; g.fillRect(0, 0, 128, 128);
      return c;
    })();

    const newOrb = () => ({
      x: Math.random() * W, y: Math.random() * H, vx: 0, vy: 0,
      r: 0.8 + Math.random() * 1.7, life: 0, max: 220 + Math.random() * 280,
    });

    function resize() {
      DPR = Math.min(2, window.devicePixelRatio || 1);
      W = host.clientWidth; H = host.clientHeight;
      canvas.width = W * DPR; canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      const n = Math.min(180, Math.max(40, Math.round((W * H) / 11000)));
      orbs = []; for (let i = 0; i < n; i++) orbs.push(newOrb());
      const nb = Math.max(6, Math.round(W / 200));
      bokeh = []; for (let j = 0; j < nb; j++) bokeh.push({
        x: Math.random() * W, y: Math.random() * H, r: 55 + Math.random() * 95,
        vx: (Math.random() - 0.5) * 0.10, vy: (Math.random() - 0.5) * 0.10, a: 0.5 + Math.random() * 0.5,
      });
    }

    const flow = (x: number, y: number) => {
      const s = 0.0017;
      return (Math.cos(x * s + Math.sin(y * s * 0.8 + t)) + Math.sin(y * s - Math.cos(x * s * 0.6 - t * 0.8))) * 1.7;
    };

    function frame() {
      raf = requestAnimationFrame(frame);
      if (!visible) return;
      t += 0.0015 + progress * 0.0018;
      ctx.clearRect(0, 0, W, H);

      for (const o of bokeh) {
        o.x += o.vx; o.y += o.vy;
        if (o.x < -o.r) o.x = W + o.r; if (o.x > W + o.r) o.x = -o.r;
        if (o.y < -o.r) o.y = H + o.r; if (o.y > H + o.r) o.y = -o.r;
        ctx.globalAlpha = o.a * (0.16 + progress * 0.06);
        ctx.drawImage(sprite, o.x - o.r, o.y - o.r, o.r * 2, o.r * 2);
      }
      ctx.globalAlpha = 1;

      const step = 0.8 * (1 + progress * 1.2);
      const cr = TEAL[0], cg = TEAL[1], cb = TEAL[2];
      for (let i = 0; i < orbs.length; i++) {
        const p = orbs[i];
        const a = flow(p.x, p.y);
        p.vx += (Math.cos(a) - p.vx) * 0.14; p.vy += (Math.sin(a) - p.vy) * 0.14;
        p.x += p.vx * step; p.y += p.vy * step;
        if (mouse.active) {
          const dx = p.x - mouse.x, dy = p.y - mouse.y, d2 = dx * dx + dy * dy;
          if (d2 < 15000) { const d = Math.sqrt(d2) || 1, f = (1 - d / 122) * 2.4; p.x += (dx / d) * f; p.y += (dy / d) * f; }
        }
        const rad = p.r * (1 + progress * 0.6);
        ctx.fillStyle = `rgba(${cr},${cg},${cb},${(0.55 + progress * 0.15).toFixed(2)})`;
        ctx.beginPath(); ctx.arc(p.x, p.y, rad, 0, 6.2832); ctx.fill();
        p.life++;
        if (p.life > p.max || p.x < -20 || p.x > W + 20 || p.y < -20 || p.y > H + 20) orbs[i] = newOrb();
      }
    }

    function onScroll() {
      const r = host.getBoundingClientRect();
      progress = Math.min(1, Math.max(0, -r.top / (host.offsetHeight * 0.9 || 1)));
    }

    window.addEventListener('resize', resize);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('pointermove', (e) => {
      const r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top; mouse.active = true;
    }, { passive: true });
    window.addEventListener('pointerleave', () => { mouse.active = false; });

    if ('IntersectionObserver' in window) {
      new IntersectionObserver((es) => { visible = es[0].isIntersecting; }, { threshold: 0 }).observe(host);
    }
    document.addEventListener('visibilitychange', () => { visible = !document.hidden; });

    resize(); onScroll();
    if (reduce) {
      for (const p of orbs) { ctx.fillStyle = 'rgba(78,205,196,0.5)'; ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, 6.2832); ctx.fill(); }
    } else {
      raf = requestAnimationFrame(frame);
    }
  }

  function boot() { document.querySelectorAll<HTMLCanvasElement>('canvas.cnl-field').forEach(initField); }
  boot();
  document.addEventListener('astro:page-load', boot);
</script>
