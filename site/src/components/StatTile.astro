---
// Stat tile: a single cited market figure. Value + label + source.
// The value is the loud element; the source keeps every claim honest
// and checkable (never a client result - see src/data/market.ts).
//
// The big number counts up from zero when the tile scrolls into view
// (driven by [data-count] in scripts/motion.js). We only opt a value in
// when it is a single clean number: ranges like "4-6 months" render as
// plain text so they are never mangled by the animation. Without JS, or
// under prefers-reduced-motion, the final value is what renders.
interface Props { value: string; label: string; source: string; class?: string; }
const { value, label, source, class: extra = '' } = Astro.props;

const isRange = /\d\s*[-–]\s*\d/.test(value);
const parts = value.match(/^([^\d]*?)([\d,]+(?:\.\d+)?)(.*)$/);
const animate = !isRange && !!parts;
const prefix = animate ? parts![1] : '';
const numText = animate ? parts![2] : '';
const suffix = animate ? parts![3] : '';
const target = animate ? parseFloat(numText.replace(/,/g, '')) : 0;
const decimals = animate && numText.includes('.') ? numText.split('.')[1].length : 0;
const sep = animate && numText.includes(',');
---

<div class={`rounded-2xl border border-navy/10 bg-white p-6 shadow-[0_10px_30px_rgba(26,43,74,0.06)] ${extra}`.trim()}>
  <div class="font-display text-4xl font-bold text-teal-dark">
    {animate ? (
      <span
        class="stat-count"
        data-count={target}
        data-decimals={decimals}
        data-sep={sep ? '1' : '0'}
      >{prefix}<span class="stat-count-num">{numText}</span>{suffix}</span>
    ) : (
      value
    )}
  </div>
  <p class="mt-2 text-sm leading-relaxed text-navy/70">{label}</p>
  <p class="mt-3 text-xs font-medium text-navy/45">Source: {source}</p>
</div>
