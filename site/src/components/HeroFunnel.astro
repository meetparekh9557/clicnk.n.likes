---
// Hero motion: "convergence" - fine teal signal-streaks sweep in from every
// edge of the hero and funnel into the live audit card on the right, then
// vanish behind it. The metaphor is the pitch itself: every channel (SEO, AI
// search, social, content) funnels into one live growth engine. Native canvas,
// brand teal only, no gradient wash. Streaks fade in and out so the navy hero
// text keeps contrast. Static (drawn once) under prefers-reduced-motion;
// paused when the hero scrolls out of view.
---
<canvas id="heroFunnel" class="pointer-events-none absolute inset-0 -z-10 h-full w-full" aria-hidden="true"></canvas>

<script>
  function initHeroFunnel() {
    const canvas = document.getElementById('heroFunnel');
    if (!canvas || canvas.dataset.on === '1') return;
    canvas.dataset.on = '1';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const ctx = canvas.getContext('2d');
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    const N = 80;
    let w = 0, h = 0, tx = 0, ty = 0, R = 1, raf = 0, running = false;
    let parts = [];

    const spawn = () => {
      const ang = Math.random() * Math.PI * 2;
      const rad = R * (0.72 + Math.random() * 0.5);
      return {
        ang,
        rad,
        radv: 1.6 + Math.random() * 3.4,
        curve: (Math.random() - 0.5) * 0.012,     // slight bend, not a swirl
        px: tx + Math.cos(ang) * rad,
        py: ty + Math.sin(ang) * rad * 0.82,
        wob: 0.7 + Math.random() * 1.3,
      };
    };

    const resize = () => {
      const r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = Math.round(w * DPR);
      canvas.height = Math.round(h * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      tx = w * 0.76;                 // the live audit card
      ty = h * 0.46;
      R = Math.hypot(w, h) * 0.62;
    };

    const step = () => {
      ctx.clearRect(0, 0, w, h);
      // faint sink glow behind the card
      const g = ctx.createRadialGradient(tx, ty, 0, tx, ty, R * 0.42);
      g.addColorStop(0, 'rgba(78,205,196,0.12)');
      g.addColorStop(1, 'rgba(78,205,196,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, w, h);

      for (const p of parts) {
        const prevx = p.px, prevy = p.py;
        p.ang += p.curve;
        p.rad -= p.radv;
        if (p.rad < 8) { Object.assign(p, spawn()); continue; }
        const x = tx + Math.cos(p.ang) * p.rad;
        const y = ty + Math.sin(p.ang) * p.rad * 0.82;
        p.px = x; p.py = y;
        const t = 1 - p.rad / R;                    // 0 far .. 1 near card
        const a = Math.min(0.5, Math.sin(t * Math.PI) * 0.55);  // fade in + out
        ctx.beginPath();
        ctx.moveTo(prevx, prevy);
        ctx.lineTo(x, y);
        ctx.strokeStyle = 'rgba(78,205,196,' + a + ')';
        ctx.lineWidth = p.wob;
        ctx.lineCap = 'round';
        ctx.stroke();
      }
    };

    // `activated` gates the very first start until the browser is idle, so
    // the decorative canvas never competes with island hydration during the
    // load window (keeps Total Blocking Time down). After that the
    // IntersectionObserver pauses/resumes it on scroll as usual.
    let activated = false;
    const tick = () => { if (!running) return; step(); raf = requestAnimationFrame(tick); };
    const start = () => { if (running || reduce || !activated) return; running = true; raf = requestAnimationFrame(tick); };
    const stop = () => { running = false; cancelAnimationFrame(raf); };

    resize();
    parts = Array.from({ length: N }, spawn);
    window.addEventListener('resize', () => { resize(); if (reduce) step(); });

    if (reduce) { step(); return; }
    const io = new IntersectionObserver((es) => {
      es[0] && es[0].isIntersecting ? start() : stop();
    }, { threshold: 0 });
    io.observe(canvas);
    // Purely visual, so a beat's delay before the streaks appear is invisible.
    const kick = () => { activated = true; start(); };
    if ('requestIdleCallback' in window) requestIdleCallback(kick, { timeout: 1200 });
    else setTimeout(kick, 600);
  }

  initHeroFunnel();
  document.addEventListener('astro:page-load', () => {
    const c = document.getElementById('heroFunnel');
    if (c) c.dataset.on = '';
    initHeroFunnel();
  });
</script>
