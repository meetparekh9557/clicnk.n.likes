---
// Hero motion: a "hole" / wormhole in the Animate UI mould, rebuilt natively
// so it fits our Astro stack (no framer-motion, no shadcn). A stack of
// concentric ellipse rings is twisted into a spiral and slowly rotated, with
// a glowing teal core at the centre - the growth funnel as a vortex pulling
// everything inward. Brand teal only, full-bleed. Outer rings stay faint so
// the navy hero text over them keeps its contrast. Static single frame under
// prefers-reduced-motion; paused when the hero scrolls out of view.
---
<canvas id="heroFunnel" class="pointer-events-none absolute inset-0 -z-10 h-full w-full" aria-hidden="true"></canvas>

<script>
  function initHeroFunnel() {
    const canvas = document.getElementById('heroFunnel');
    if (!canvas || canvas.dataset.on === '1') return;
    canvas.dataset.on = '1';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const ctx = canvas.getContext('2d');
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    const RINGS = 46;
    let w = 0, h = 0, cx = 0, cy = 0, R = 1, rot = 0, t0 = 0, raf = 0, running = false;

    const resize = () => {
      const r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = Math.round(w * DPR);
      canvas.height = Math.round(h * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      cx = w * 0.58;                 // core sits toward the audit card
      cy = h * 0.5;
      R = Math.hypot(w, h) * 0.62;   // reaches past the corners = full-bleed
    };

    const draw = (now) => {
      const pulse = 1 + Math.sin(now / 1400) * 0.05;
      ctx.clearRect(0, 0, w, h);

      // luminous core (the light down the hole)
      const core = ctx.createRadialGradient(cx, cy, 0, cx, cy, R * 0.5);
      core.addColorStop(0, 'rgba(78,205,196,0.30)');
      core.addColorStop(0.18, 'rgba(78,205,196,0.12)');
      core.addColorStop(0.5, 'rgba(78,205,196,0.03)');
      core.addColorStop(1, 'rgba(78,205,196,0)');
      ctx.fillStyle = core;
      ctx.fillRect(0, 0, w, h);

      // twisted concentric rings -> the vortex
      for (let i = 0; i < RINGS; i++) {
        const t = i / RINGS;                      // 0 outer .. 1 inner
        const rx = R * (1 - t * 0.985) * pulse;
        const ry = rx * 0.5;
        const a = rot * (1 + t * 0.6) + t * Math.PI * 1.5;   // progressive twist
        const alpha = 0.05 + t * t * 0.5;         // faint outside, bright core
        ctx.save();
        ctx.translate(cx, cy);
        ctx.rotate(a);
        ctx.beginPath();
        ctx.ellipse(0, 0, Math.max(0.5, rx), Math.max(0.5, ry), 0, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(78,205,196,' + Math.min(0.55, alpha) + ')';
        ctx.lineWidth = 0.7 + t * 1.4;
        ctx.stroke();
        ctx.restore();
      }
    };

    const tick = (now) => {
      if (!running) return;
      if (!t0) t0 = now;
      rot = (now - t0) * 0.00016;
      draw(now);
      raf = requestAnimationFrame(tick);
    };
    const start = () => { if (running || reduce) return; running = true; raf = requestAnimationFrame(tick); };
    const stop = () => { running = false; cancelAnimationFrame(raf); };

    resize();
    window.addEventListener('resize', () => { resize(); if (reduce) draw(0); });

    if (reduce) { draw(0); return; }              // one static frame, no motion
    const io = new IntersectionObserver((es) => {
      es[0] && es[0].isIntersecting ? start() : stop();
    }, { threshold: 0 });
    io.observe(canvas);
    start();
  }

  initHeroFunnel();
  document.addEventListener('astro:page-load', () => {
    const c = document.getElementById('heroFunnel');
    if (c) c.dataset.on = '';
    initHeroFunnel();
  });
</script>
