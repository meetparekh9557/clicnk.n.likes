---
// Hero motion: a subtle, monochrome "growth funnel" - faint teal particles
// orbit and spiral inward into a single point (the conversion sink) behind
// the audit card, so many visitors visibly converge into one lead. Canvas,
// brand teal only (no colour wash), low opacity so the white hero and navy
// text stay clean. Frozen entirely under prefers-reduced-motion, and paused
// when the hero scrolls out of view.
---
<canvas id="heroFunnel" class="pointer-events-none absolute inset-0 -z-10 h-full w-full" aria-hidden="true"></canvas>

<script>
  function initHeroFunnel() {
    const canvas = document.getElementById('heroFunnel');
    if (!canvas || canvas.dataset.on === '1') return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    canvas.dataset.on = '1';
    const ctx = canvas.getContext('2d');
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0, cx = 0, cy = 0, raf = 0, running = false;
    const N = 96;
    let parts = [];

    const spawn = () => {
      const reach = Math.max(w, h) * 0.5;
      return {
        ang: Math.random() * Math.PI * 2,
        rad: reach * (0.55 + Math.random() * 0.6),
        radv: 0.35 + Math.random() * 0.7,
        size: 0.7 + Math.random() * 1.7,
      };
    };

    const resize = () => {
      const r = canvas.getBoundingClientRect();
      w = r.width; h = r.height;
      canvas.width = Math.round(w * DPR);
      canvas.height = Math.round(h * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      cx = w * 0.72;               // sink sits behind the audit card
      cy = h * 0.46;
    };

    const reach = () => Math.max(w, h) * 0.5;
    const tick = () => {
      if (!running) return;
      ctx.clearRect(0, 0, w, h);
      const R = reach();
      for (const p of parts) {
        const near = 1 - Math.min(1, p.rad / R);
        p.ang += 0.004 + near * 0.02;   // spin faster as it nears the sink
        p.rad -= p.radv * (0.5 + near);
        if (p.rad < 5) Object.assign(p, spawn(), { rad: R * (0.9 + Math.random() * 0.3) });
        const x = cx + Math.cos(p.ang) * p.rad;
        const y = cy + Math.sin(p.ang) * p.rad * 0.6;   // elliptical funnel
        const a = Math.min(0.28, (p.rad / R) * 0.3);
        ctx.beginPath();
        ctx.arc(x, y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(78,205,196,' + a + ')';
        ctx.fill();
      }
      raf = requestAnimationFrame(tick);
    };

    const start = () => { if (running) return; running = true; raf = requestAnimationFrame(tick); };
    const stop = () => { running = false; cancelAnimationFrame(raf); };

    resize();
    parts = Array.from({ length: N }, spawn);
    window.addEventListener('resize', resize);

    // Only animate while the hero is on screen.
    const io = new IntersectionObserver((es) => {
      es[0] && es[0].isIntersecting ? start() : stop();
    }, { threshold: 0 });
    io.observe(canvas);
    start();
  }

  initHeroFunnel();
  document.addEventListener('astro:page-load', () => {
    const c = document.getElementById('heroFunnel');
    if (c) c.dataset.on = '';
    initHeroFunnel();
  });
</script>
