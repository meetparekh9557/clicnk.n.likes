---
// Site-wide background current. A single FIXED, full-viewport canvas that
// stays put while the page scrolls, so its scroll reaction (orbs grow,
// brighten and warm) is actually visible the whole way down - unlike a
// hero-anchored canvas, which scrolls away before it can react. Rendered
// once from Base, behind all content (z-index:-1). Content sections carry
// their own solid backgrounds, so the current reads in the open areas
// (hero, gaps) and never fights body text. One canvas, no library, capped
// particle count, rAF, paused when the tab is hidden, static under
// prefers-reduced-motion.
---
<canvas id="cnl-backdrop" aria-hidden="true"></canvas>

<style>
  #cnl-backdrop {
    position: fixed; inset: 0; z-index: -1;
    width: 100vw; height: 100vh; pointer-events: none;
  }
</style>

<script>
  function initBackdrop() {
    const canvas = document.getElementById('cnl-backdrop') as HTMLCanvasElement | null;
    if (!canvas || (canvas as any)._cnlInit) return;
    (canvas as any)._cnlInit = true;
    const ctx = canvas.getContext('2d', { alpha: true });
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let W = 0, H = 0, DPR = 1, orbs: any[] = [], bokeh: any[] = [], t = 0, progress = 0, hidden = false;
    const mouse = { x: -9999, y: -9999, active: false };
    const TEAL = [78, 205, 196], CORAL = [255, 71, 87];

    const sprite = (() => {
      const c = document.createElement('canvas'); c.width = c.height = 128;
      const g = c.getContext('2d')!;
      const rad = g.createRadialGradient(64, 64, 0, 64, 64, 64);
      rad.addColorStop(0, 'rgba(78,205,196,0.30)');
      rad.addColorStop(0.5, 'rgba(78,205,196,0.09)');
      rad.addColorStop(1, 'rgba(78,205,196,0)');
      g.fillStyle = rad; g.fillRect(0, 0, 128, 128);
      return c;
    })();

    const newOrb = () => ({
      x: Math.random() * W, y: Math.random() * H, vx: 0, vy: 0,
      r: 0.8 + Math.random() * 1.6, life: 0, max: 240 + Math.random() * 300,
    });

    function resize() {
      DPR = Math.min(2, window.devicePixelRatio || 1);
      W = window.innerWidth; H = window.innerHeight;
      canvas.width = W * DPR; canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      const n = Math.min(150, Math.max(36, Math.round((W * H) / 13500)));
      orbs = []; for (let i = 0; i < n; i++) orbs.push(newOrb());
      const nb = Math.max(6, Math.round(W / 220));
      bokeh = []; for (let j = 0; j < nb; j++) bokeh.push({
        x: Math.random() * W, y: Math.random() * H, r: 60 + Math.random() * 95,
        vx: (Math.random() - 0.5) * 0.09, vy: (Math.random() - 0.5) * 0.09, a: 0.5 + Math.random() * 0.5,
      });
    }

    const flow = (x: number, y: number) => {
      const s = 0.0017;
      return (Math.cos(x * s + Math.sin(y * s * 0.8 + t)) + Math.sin(y * s - Math.cos(x * s * 0.6 - t * 0.8))) * 1.7;
    };
    const lerp = (a: number, b: number, m: number) => a + (b - a) * m;

    function frame() {
      requestAnimationFrame(frame);
      if (hidden) return;
      t += 0.0014 + progress * 0.0018;
      ctx.clearRect(0, 0, W, H);

      for (const o of bokeh) {
        o.x += o.vx; o.y += o.vy;
        if (o.x < -o.r) o.x = W + o.r; if (o.x > W + o.r) o.x = -o.r;
        if (o.y < -o.r) o.y = H + o.r; if (o.y > H + o.r) o.y = -o.r;
        ctx.globalAlpha = o.a * (0.14 + progress * 0.06);
        ctx.drawImage(sprite, o.x - o.r, o.y - o.r, o.r * 2, o.r * 2);
      }
      ctx.globalAlpha = 1;

      const step = 0.78 * (1 + progress * 1.3);
      const cr = lerp(TEAL[0], CORAL[0], progress * 0.45) | 0;
      const cg = lerp(TEAL[1], CORAL[1], progress * 0.45) | 0;
      const cb = lerp(TEAL[2], CORAL[2], progress * 0.45) | 0;
      const alpha = (0.5 + progress * 0.18).toFixed(2);
      ctx.fillStyle = `rgba(${cr},${cg},${cb},${alpha})`;

      for (let i = 0; i < orbs.length; i++) {
        const p = orbs[i];
        const a = flow(p.x, p.y);
        p.vx += (Math.cos(a) - p.vx) * 0.14; p.vy += (Math.sin(a) - p.vy) * 0.14;
        p.x += p.vx * step; p.y += p.vy * step;
        if (mouse.active) {
          const dx = p.x - mouse.x, dy = p.y - mouse.y, d2 = dx * dx + dy * dy;
          if (d2 < 15000) { const d = Math.sqrt(d2) || 1, f = (1 - d / 122) * 2.4; p.x += (dx / d) * f; p.y += (dy / d) * f; }
        }
        const rad = p.r * (1 + progress * 0.7);
        ctx.beginPath(); ctx.arc(p.x, p.y, rad, 0, 6.2832); ctx.fill();
        p.life++;
        if (p.life > p.max || p.x < -20 || p.x > W + 20 || p.y < -20 || p.y > H + 20) orbs[i] = newOrb();
      }
    }

    function onScroll() {
      const doc = document.documentElement;
      const max = (doc.scrollHeight - window.innerHeight) || 1;
      progress = Math.min(1, Math.max(0, window.scrollY / max));
    }

    window.addEventListener('resize', resize);
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('pointermove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; mouse.active = true; }, { passive: true });
    window.addEventListener('pointerleave', () => { mouse.active = false; });
    document.addEventListener('visibilitychange', () => { hidden = document.hidden; });

    resize(); onScroll();
    if (reduce) {
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = 'rgba(78,205,196,0.5)';
      for (const p of orbs) { ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, 6.2832); ctx.fill(); }
    } else {
      requestAnimationFrame(frame);
    }
  }
  initBackdrop();
  document.addEventListener('astro:page-load', initBackdrop);
</script>
