---
// Site footer: brand + socials, service links, company links, contact,
// legal strip. Content matches v1's footer; the newsletter form returns
// with the forms/Apps Script wiring milestone so nothing ships dead.
// Brand glyphs (Instagram/LinkedIn) are inline SVGs from v1 - Lucide
// carries no brand icons.
import { services, primaryNav, moreNav, contact } from '../data/site';
import { withBase } from '../lib/url';

const year = new Date().getFullYear();
const linkCls = 'block py-1 text-sm text-white/65 transition-colors hover:text-teal';
const socialCls =
  'inline-flex h-9 w-9 items-center justify-center rounded-[10px] border border-white/20 text-white/75 transition-colors hover:border-teal hover:text-teal';
---

<footer class="bg-navy text-white/80">
  <div class="mx-auto grid max-w-6xl gap-10 px-[5vw] py-16 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div class="sm:col-span-2 lg:col-span-1">
      <img src={withBase('/logo-wordmark.png')} alt="Click.n.likes" width="144" height="24" class="h-[24px] w-auto brightness-0 invert" />
      <p class="mt-4 max-w-[280px] text-[13.5px] leading-relaxed text-white/60">
        Full-stack organic growth for SaaS, manufacturers, legal and professional firms, D2C brands and local
        businesses, anywhere in the world. SEO, AI Search, Social, Content, Websites, Paid.
      </p>
      <div class="mt-5 flex gap-3.5">
        <a href={contact.instagram} target="_blank" rel="noopener" aria-label="Instagram" class={socialCls}>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.5"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={contact.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class={socialCls}>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S.02 4.88.02 3.5C.02 2.12 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V23h-4V8zm7.5 0h3.8v2.05h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V23h-4v-7.9c0-1.88-.03-4.3-2.62-4.3-2.62 0-3.02 2.05-3.02 4.17V23H8V8z"/></svg>
        </a>
      </div>
    </div>

    <div>
      <h2 class="mb-4 text-[13px] font-semibold tracking-[0.08em] text-white uppercase">Services</h2>
      {services.map((s) => <a href={withBase(s.href)} class={linkCls}>{s.title}</a>)}
    </div>

    <div>
      <h2 class="mb-4 text-[13px] font-semibold tracking-[0.08em] text-white uppercase">Company</h2>
      {primaryNav.map((item) => <a href={withBase(item.href)} class={linkCls}>{item.title}</a>)}
      <a href={withBase('/why-organic/')} class={linkCls}>Why Organic</a>
      {moreNav.map((item) => <a href={withBase(item.href)} class={linkCls}>{item.title}</a>)}
      <a href={withBase('/contact/')} class={linkCls}>Contact</a>
    </div>

    <div>
      <h2 class="mb-4 text-[13px] font-semibold tracking-[0.08em] text-white uppercase">Contact</h2>
      <a href={`mailto:${contact.email}`} class={`${linkCls} flex items-center gap-2`}>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        {contact.email}
      </a>
      <a href={contact.whatsappHref} target="_blank" rel="noopener" class={`${linkCls} flex items-center gap-2`}>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2c-5.5 0-9.96 4.46-9.96 9.96 0 1.76.46 3.45 1.34 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22c5.5 0 9.96-4.46 9.96-9.96 0-2.66-1.04-5.16-2.92-7.04A9.9 9.9 0 0 0 12.04 2zm0 18.13a8.23 8.23 0 0 1-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.19 8.19 0 0 1 2.41 5.83c0 4.55-3.7 8.24-8.24 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.7-.81-.23-.08-.39-.12-.56.13-.16.24-.64.8-.78.97-.15.16-.29.18-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.5.11-.11.25-.29.37-.43.12-.15.16-.25.25-.42.08-.16.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43l-.48-.01c-.16 0-.43.06-.66.31-.22.24-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.16 1.75 2.67 4.24 3.75.59.25 1.05.4 1.41.52.59.19 1.13.16 1.56.1.47-.07 1.47-.6 1.68-1.18.2-.58.2-1.08.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
        {contact.whatsappDisplay}
      </a>
      <p class="mt-1 flex items-center gap-2 py-1 text-sm text-white/65">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 12-9 12S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {contact.location}
      </p>
    </div>
  </div>

  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 border-t border-white/10 px-[5vw] py-6 text-[12.5px] text-white/50">
    <span>© {year} Click.n.likes. All rights reserved.</span>
    <span>
      <a href={withBase('/privacy/')} class="transition-colors hover:text-teal">Privacy</a>
      <span class="mx-1">·</span>
      <a href={withBase('/terms/')} class="transition-colors hover:text-teal">Terms</a>
    </span>
    <span>Click The Future.</span>
  </div>
</footer>
