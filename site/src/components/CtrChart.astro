---
// Self-drawing emphasis bar chart: Google CTR by search position.
// One accent hue (#1, the point) + de-emphasis gray (the rest), per the
// dataviz method — the story is "the top spot dwarfs everything below."
// Bars are plain HTML (reliable, responsive), self-draw on scroll via
// the shared .reveal → .in observer, and degrade to full-width without
// JS (the `.js` flag is set in Base's head). Accessible: role=img with a
// summary label plus a visually-hidden data table.
import { ctrByPosition, ctrSource } from '../data/market';

const max = Math.max(...ctrByPosition.map((d) => d.ctr));
---

<figure
  class="reveal ctr-chart rounded-2xl border border-navy/10 bg-white p-6 shadow-[0_10px_30px_rgba(26,43,74,0.06)] sm:p-8"
  role="img"
  aria-label={`Google organic click-through rate by result position. Position 1 gets ${ctrByPosition[0].ctr}% of clicks; it falls sharply after that. Source: ${ctrSource}.`}
>
  <figcaption class="mb-1 font-display text-lg font-semibold text-navy">
    Where the clicks actually go
  </figcaption>
  <p class="mb-6 text-sm text-navy/60">
    Share of clicks by Google search position. The first result takes more than the next three combined — which is
    why ranking, not just showing up, is the whole game.
  </p>

  <div class="flex flex-col gap-2.5">
    {ctrByPosition.map((d, i) => (
      <div class="grid grid-cols-[2.5rem_1fr_3rem] items-center gap-3">
        <span class="text-right text-[13px] font-semibold text-navy/55 tabular-nums">#{d.position}</span>
        <span class="ctr-track relative h-5 rounded-r bg-navy/[0.04]">
          <span
            class="ctr-bar absolute inset-y-0 left-0 rounded-r"
            data-hl={d.highlight ? '' : undefined}
            style={`--target:${(d.ctr / max) * 100}%; --i:${i}`}
          ></span>
        </span>
        <span class={`text-[13px] font-semibold tabular-nums ${d.highlight ? 'text-teal-dark' : 'text-navy/70'}`}>
          {d.ctr}%
        </span>
      </div>
    ))}
  </div>

  <p class="mt-6 text-xs text-navy/45">Source: {ctrSource}</p>

  <!-- Screen-reader data table. Wrapped in an sr-only DIV (not applied to
       the table itself): a <table> auto-sizes to its content and ignores
       sr-only's 1px width, which would silently widen the page. The div
       clips it to zero footprint while keeping it readable to AT. -->
  <div class="sr-only">
    <table>
      <caption>Google organic click-through rate by result position</caption>
      <thead><tr><th>Position</th><th>Click-through rate</th></tr></thead>
      <tbody>
        {ctrByPosition.map((d) => (
          <tr><td>#{d.position}</td><td>{d.ctr}%</td></tr>
        ))}
      </tbody>
    </table>
  </div>
</figure>
