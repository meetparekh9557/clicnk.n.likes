---
// Client logo wall. Single-tone by default (grayscale + dimmed), full
// colour + lift on hover, per the founder's spec. Logos only, no names.
// White backgrounds were stripped at build-prep so they blend on the
// light surface. `limit` trims the set (homepage strip vs full Work grid).
// `gridCols` switches from centred wrap to an even grid (equal gaps, no
// ragged last row) - e.g. "grid-cols-2 sm:grid-cols-5" for a clean 2x5.
import { clients } from '../data/clients';
import { withBase } from '../lib/url';

interface Props { limit?: number; class?: string; gridCols?: string; }
const { limit, class: extra = '', gridCols } = Astro.props;
const list = limit ? clients.slice(0, limit) : clients;
const wrapCls = gridCols
  ? `grid ${gridCols} place-items-center gap-x-8 gap-y-9 ${extra}`
  : `flex flex-wrap items-center justify-center gap-x-10 gap-y-8 ${extra}`;
---

<div class={wrapCls.trim()}>
  {list.map((c) => (
    <img
      src={withBase(`/clients/${c.slug}.png`)}
      alt={c.name}
      loading="lazy"
      decoding="async"
      class="h-8 w-auto max-w-[128px] object-contain opacity-55 grayscale transition duration-300 ease-out-quart hover:-translate-y-0.5 hover:opacity-100 hover:grayscale-0 sm:h-10"
    />
  ))}
</div>
